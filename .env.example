# Database (Vercel Postgres / Neon)
# Direct connection (for migrations)
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Pooler connection (for runtime)
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Admin seed (used when first admin registers)
ADMIN_EMAIL=""

# Upstash Redis (Vercel KV) - for rate limiting
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# HTTP Proxy (for accessing OpenAI API, remove in production/Vercel)
# https_proxy="http://127.0.0.1:7897"
